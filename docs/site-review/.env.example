# Copy this file to .env and fill in your API keys.
# Never commit .env to version control.

# Anthropic (Claude)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (GPT)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google AI Studio (Gemini)
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# xAI (Grok)
# https://console.x.ai/
XAI_API_KEY=

# Optional: override the default budget cap per run, in USD.
# Default is 2.00. The run aborts if projected cost exceeds this.
# SITE_REVIEW_MAX_BUDGET_USD=2.00

# Optional: override the project root for runs/ and data/ folders.
# Useful if you want artifacts in a different location than the code.
# SITE_REVIEW_DATA_DIR=
