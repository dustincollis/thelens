# Required for v1
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional — Gemini and Grok client implementations are deferred (see SPEC section 16)
GOOGLE_API_KEY=
XAI_API_KEY=

# Optional — CodeMie (EPAM internal AI gateway). When set, can be used as
# a fourth provider that routes to GPT/Claude/Gemini through EPAM's
# infrastructure. Get credentials from https://epa.ms/codemie-support.
CODEMIE_CLIENT_ID=
CODEMIE_CLIENT_SECRET=
CODEMIE_ASSISTANT_ID=
# CODEMIE_TOKEN_URL=https://auth.epam.com/realms/codemie-prod/protocol/openid-connect/token
# CODEMIE_API_URL=https://codemie.lab.epam.com/code-assistant-api
